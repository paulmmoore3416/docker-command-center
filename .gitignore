# ============================================================
# Docker Command Center — .gitignore
# ============================================================

# ------ Compiled Binaries ------
/dcc
bin/
dist/
# Allow Windows installer
!dist/DockerCommandCenter-Setup.exe
*.deb
*.rpm
*.tar.gz
*.zip

# ------ Frontend Build Output ------
frontend/dist/
frontend/node_modules/

# ------ Go Build Artifacts ------
*.exe
# Allow Windows installer
!dist/DockerCommandCenter-Setup.exe
*.test
*.out
vendor/

# ------ Environment & Secrets ------
.env
.env.*
*.key
*.pem
*.cert
*.crt
*.p12
secrets/
credentials/

# ------ Runtime / Logs ------
*.log
dcc-audit.log
/tmp/

# ------ IDE & Editor ------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------ Claude Code Local Config ------
.claude/settings.local.json

# ------ OS Artifacts ------
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini
$RECYCLE.BIN/

# ------ Test Coverage ------
coverage.out
coverage.html

# ------ Large Binaries (not for git) ------
minikube-linux-amd64
minikube-*

# ------ Internal AI Reference Files ------
aisharedreference.md

# ------ Internal Planning & Session Documents ------
OPTIMIZATION_*.md
PERFORMANCE_COMPARISON.md
SYSTEM_STATUS_*.md
UPDATE_SUMMARY_*.md
DEPLOYMENT_REPORT.md
BUILD_DEPLOYMENT_SUMMARY.txt
START_HERE.md
